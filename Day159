//365. Water and Jug Problem



class Solution {
    public boolean canMeasureWater(int x, int y, int target) {
        if(x+y < target){
            return false;
        }
        int gcd=1;
        for(int i=2;i<=Math.min(x,y);i++){
            if(x%i==0 && y%i==0){
                gcd=i;
            }
        }
        if(target%gcd==0){
            return true;
        }
        return false;
    }
}
