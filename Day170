// 1306. Jump Game III


class Solution {
    public boolean canReach(int[] arr, int start) {
        return dfs(arr,start);
    }
    boolean dfs(int [] arr, int i){
        if(i<0 || i>=arr.length || arr[i]<0){
            return false;
        }
        if(arr[i]==0){
            return true;
        }
        arr[i]*=-1;
        boolean a=dfs(arr,i+arr[i]);
        boolean b=dfs(arr,i-arr[i]);
        return a||b;
    }
}
