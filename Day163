// 171. Excel Sheet Column



class Solution {
    public int titleToNumber(String ct) {
        int n=ct.length();
        int ans=0;
        int p=0;
        for(int i=n-1;i>=0;i--){
            int val=(int)(ct.charAt(i)-'A');
            int sum = (int)(Math.pow(26,p)) * (1+val);
            ans=ans+sum;
            p++;
        }
        return ans;
        
    }
}
