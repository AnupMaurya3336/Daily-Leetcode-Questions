// 396. Rotate Function




class Solution {
    public int maxRotateFunction(int[] nums) {
        int n=nums.length;

        int f=0;
        int sum=0;

        for(int i=0;i<n;i++){
            sum+=nums[i];
            f+=i*nums[i];
        }
        int result=f;
        for(int i=0;i<n-1;i++){
            int newf=f+sum-n*nums[n-1-i];
            result=Math.max(result,newf);
            f=newf;

        }
        return result;
        
    }
}
